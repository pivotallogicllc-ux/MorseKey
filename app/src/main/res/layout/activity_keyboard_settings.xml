<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Keyboard Layout"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <RadioGroup
        android:id="@+id/layoutSelectionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_single_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Single Button (Tap/Hold)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="12dp"/>

        <RadioButton
            android:id="@+id/radio_split_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Split Screen (Dot Left / Dash Right)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="12dp"/>

        <RadioButton
            android:id="@+id/radio_swipe_zone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Swipe Zone (Swipe Left/Right)"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:padding="12dp"/>
    </RadioGroup>

</LinearLayout>


