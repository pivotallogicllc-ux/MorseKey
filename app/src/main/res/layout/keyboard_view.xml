<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0A0A0A"
    android:paddingBottom="16dp"
    android:paddingTop="8dp">

    <LinearLayout
        android:id="@+id/layout_single"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone">
        <Button
            android:id="@+id/morse_input_zone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_morse_key"
            android:text="TAP / HOLD"
            android:textColor="#00FF00"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null" /> </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_split"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:visibility="gone">
        <Button
            android:id="@+id/btn_dot"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_morse_key"
            android:text="DOT"
            android:textColor="#00FF00"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"/>
        <Button
            android:id="@+id/btn_dash"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_morse_key"
            android:text="DASH"
            android:textColor="#0088FF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_swipe"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone">
        <Button
            android:id="@+id/swipe_anchor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_morse_key"
            android:text="SWIPE L / R"
            android:textColor="#AAAAFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null" />
    </LinearLayout>

</FrameLayout>


